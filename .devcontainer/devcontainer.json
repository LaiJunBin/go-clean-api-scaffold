{
	"name": "Hello World Dev Container",
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.yml"
	],
	"service": "app",
	"workspaceFolder": "/app/go-clean-api-scaffold",
	"forwardPorts": [8080],
	"postCreateCommand": "git config --global --add safe.directory /app",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go",
				"Arjun.swagger-viewer",
				"ms-azuretools.vscode-docker"
			]
		}
	}
}
